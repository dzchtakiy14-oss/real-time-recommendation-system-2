{
  "id": null,
  "title": "FastAPI + Redis Monitoring",
  "tags": ["Production", "FastAPI", "Redis"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "QPS per Endpoint",
      "gridPos": {"x":0,"y":0,"w":12,"h":6},
      "targets": [
        {
          "expr": "sum(rate(request_count_total[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency P95 per Endpoint",
      "gridPos": {"x":12,"y":0,"w":12,"h":6},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(request_latency_seconds_bucket[1m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate %",
      "gridPos": {"x":0,"y":6,"w":12,"h":6},
      "targets": [
        {
          "expr": "sum(rate(error_count_total[1m])) / sum(rate(request_count_total[1m])) * 100",
          "legendFormat": "Error Rate %"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis Memory Used",
      "gridPos": {"x":12,"y":6,"w":12,"h":6},
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Redis Memory"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis Connected Clients",
      "gridPos": {"x":0,"y":12,"w":12,"h":6},
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Redis Connections"
        }
      ]
    }
  ]
}